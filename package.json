{
  "name": "signalcut",
  "version": "0.1.0",
  "description": "A CLI-first, BYOK developer tool that extracts noise-free technical documentation, API references, and GitHub insights.",
  "keywords": [
    "cli",
    "documentation",
    "developer-tools",
    "llm",
    "byok",
    "api"
  ],
  "license": "MIT",
  "author": "Sagar Jajoriya",
  "homepage": "https://github.com/sagarjajoriya/signalcut#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sagarjajoriya/signalcut.git"
  },
  "bugs": {
    "url": "https://github.com/sagarjajoriya/signalcut/issues"
  },
  "type": "module",
  "bin": {
    "signalcut": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "check": "tsup scripts/check-extract.ts --format esm --platform node --out-dir .sc-check --no-config && node .sc-check/check-extract.js && rm -rf .sc-check",
    "clean": "rm -rf dist .sc-check",
    "prepack": "npm run build",
    "prepublishOnly": "npm run clean && npm run typecheck && npm run check && npm run build"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.112.5",
    "@google/genai": "^2.13.0",
    "@mozilla/readability": "^0.5.0",
    "commander": "^12.1.0",
    "jsdom": "^24.1.1",
    "openai": "^4.56.0",
    "picocolors": "^1.0.1",
    "turndown": "^7.2.0",
    "turndown-plugin-gfm": "^1.0.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/jsdom": "^21.1.7",
    "@types/node": "^20.14.15",
    "@types/turndown": "^5.0.5",
    "tsup": "^8.2.4",
    "typescript": "^5.5.4"
  }
}
